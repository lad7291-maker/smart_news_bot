    "Наука": ["исследован", "ученые", "открытие", "ген", "медицин", "вакцин", "наса", "nasa", "марс", "луна", "днк", "физик", "химия", "биолог", "эксперимент", "ученый"],
    "Развлечения": ["кино", "фильм", "сериал", "музыка", "концерт", "игра", "шоу", "звезда", "актер", "режиссер", "холивуд", "netflix", "oscar", "оскар", "премия", "фестиваль", "книга", "бестселлер"],
}


def _classify_topic(title: str, summary: str) -> str:
    """AI-классификация темы по ключевым словам (P3-006)."""
    text = f"{title} {summary}".lower()
    scores = {}
    for topic, keywords in _TOPIC_KEYWORDS.items():
        score = sum(1 for kw in keywords if kw.lower() in text)
        if score > 0:
            scores[topic] = score
    if not scores:
        return ""
    sorted_topics = sorted(scores.items(), key=lambda x: x[1], reverse=True)
    top = [t for t, s in sorted_topics if s >= 2][:2]
    if not top and sorted_topics:
        top = [sorted_topics[0][0]]
    return " ".join(f"#{t}" for t in top)


# ===== IMPROVED FORMAT (2026-06-11) =====

def format_news_post(article, variant_config=None):
    """
    Форматирует пост с AI-анализом.
    Improved format: ⚡ + flag + заголовок, цитата, AI-контекст, скоринг, CTA, хештеги.
    """
    title = (article.get("title", "") or "").strip()
    summary = article.get("summary", "") or ""
    link = article.get("link", "")
    source = article.get("source", "News")
    ai_comment = (article.get("ai_comment") or "").strip()
    score = article.get("score", 5)

    # UTM-метки для отслеживания трафика
    if link:
        utm = "utm_source=smartnewsai&utm_medium=telegram&utm_campaign=news_post"
        if "?" in link:
            link = link + "&" + utm
        else:
            link = link + "?" + utm
        article["link"] = link

    # Default variant config
    if variant_config is None:
        variant_config = {
            "has_ai_comment": True,
            "has_closer_question": True,
            "has_summary": False,
        }

    # === ЗАГОЛОВОК ===
    flag = _detect_country_flag(title, summary)
    header = f"⚡ {flag} <b>{_escape_html(title)}</b>"

    # === ЦИТАТА ===
    quote_block = ""
    article_quote = article.get("quote", "").strip()
    if article_quote and len(article_quote) > 10:
        quote_clean = article_quote.replace("**", "").replace(chr(34), "")
        if len(quote_clean) > 300:
            quote_clean = quote_clean[:300].rstrip() + "..."
        quote_block = f"\n💬 <i>«{_escape_html(quote_clean)}»</i>\n"

    # === ТЕЛО (AI-комментарий или summary) ===
    ai_block = ""
    if variant_config.get("has_ai_comment", True) and ai_comment:
        ai_clean = ai_comment.replace("📌 ", "").replace("📚 ", "").replace("✅ ", "")
        ai_clean = ai_clean.replace("**", "").replace("— ", "• ")
        ai_block = f"{_escape_html(ai_clean)}"
    elif summary:
        summary_clean = " ".join(summary.split())
        if len(summary_clean) > 20:
            if len(summary_clean) > 500:
                summary_clean = summary_clean[:500].rstrip() + "…"
            ai_block = f"{_escape_html(summary_clean)}"

    # Разбиваем на абзацы (2-3 предложения каждый)
    body_paragraphs = []
    if ai_block:
        sentences = ai_block.split(". ")
        if len(sentences) > 3:
            mid = len(sentences) // 2
            p1 = ". ".join(sentences[:mid]) + ("." if not sentences[:mid][-1].endswith(".") else "")
            p2 = ". ".join(sentences[mid:])
            body_paragraphs = [p1.strip(), p2.strip()]
        else:
            body_paragraphs = [ai_block.strip()]

    body = "\n\n".join(body_paragraphs)

    # === AI-КОНТЕКСТ (если отдельный от основного) ===
    ai_context = ""
    if ai_comment and "📌" not in ai_comment:
        ai_context = f"\n🧠 <b>Почему это важно:</b>\n{_escape_html(ai_comment[:200])}"

    # === СКОРИНГ + ВРЕМЯ ЧТЕНИЯ ===
    importance_emoji = "🔴" if score >= 8 else "🟠" if score >= 5 else "🟢"
    read_time = max(30, len(body) // 20)
    meta = f"\n{importance_emoji} <b>Важность:</b> {score}/10 | ⏱️ <b>Читать:</b> {read_time} сек"

    # === CTA ===
    closer = ""
    if variant_config.get("has_closer_question", True):
        closers = ["", "", "", "", "Что думаете?", "Обсуждаем?", "Как считаете — это серьёзно?", "Похоже на правду?"]
        closer_raw = __import__("random").choice(closers)
        if closer_raw:
            closer = f"\n{_escape_html(closer_raw)}\n"

    cta = f"👉 <b>Smart_News_AI</b> — подписаться"
    link_text = f"🔗 <a href=\"{link}\">Читать полностью</a>"

    # === ХЕШТЕГИ ===
    hashtags = _classify_topic(title, summary)
    if hashtags:
        hashtags = f"\n\n{hashtags} #Новости"
    else:
        hashtags = "\n\n#Новости"

    # === СОБИРАЕМ ВСЁ ===
    message = f"""{header}{quote_block}

{body}{ai_context}{meta}

{closer}{cta}

{link_text}{hashtags}"""
    return message.strip()


def format_digest_post(articles: list) -> str:
    """Формирует дайджест из нескольких новостей."""
    if not articles:
        return "📭 Нет новостей"

    header = "📬 <b>Дайджест новостей</b>\n\n"
    lines = []
    for i, article in enumerate(articles[:5], 1):
        flag = _detect_country_flag(article.get("title", ""), article.get("summary", ""))
        title = article.get("title", "")[:80]
        link = article.get("link", "")
        score = article.get("score", 5)
        emoji = "🔴" if score >= 8 else "🟠" if score >= 5 else "🟢"
        lines.append(f"{i}. {emoji} {flag} <a href='{link}'>{_escape_html(title)}</a>")

    footer = "\n\n👉 <b>Smart_News_AI</b> — подписаться"
    return header + "\n".join(lines) + footer
