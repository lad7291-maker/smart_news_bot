    "Технологии": ["AI", "ии", "искусственный интеллект", "нейросеть", "apple", "google", "microsoft", "meta", "телефон", "приложение", "кибер", "хакер", "квант", "космос", "spacex", "tesla", "nvidia", "чип", "процессор", "смартфон", "IT", "технолог", "робот", "дрон"],
