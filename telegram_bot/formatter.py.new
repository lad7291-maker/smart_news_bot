def _detect_country_flag(title: str, summary: str) -> str:
    text = f"{title} {summary}".lower()
    for country, flag in _COUNTRY_FLAGS.items():
        if country in text:
            return flag
    return chr(9889)

_TOPIC_KEYWORDS = {
    "Политика": ["президент", "санкци", "выборы", "парламент", "правительство", "закон", "трамп", "путин", "байден", "нато", "ес ", "ес,", "конфликт", "война", "переговоры", "дипломат", "голосование", "партия", "оппозиция", "госдума", "конгресс", "сша", "россия", "украин", "китай", "иран", "израил"],
