"""
Модуль форматирования постов с AI-анализом.
- HTML-разметка (без Markdown).
- AI-комментарий выводится как основное содержание поста (с префиксом 📌).
- AI-комментарий должен быть передан в статье под ключом 'ai_comment'.
- Эмодзи определяются по содержанию новости (тема/страна/сфера), а не по источнику.
- P0-002: Все динамические строки экранируются для безопасного HTML.
- P2-001: Эмодзи загружаются из config/emojis.yaml.
"""

from telegram_bot.emoji_loader import get_emoji_config


def _detect_topic_emoji(title, summary, source):
    """
    P2-001: Определяет эмодзи по содержанию новости.
    Правила загружаются из config/emojis.yaml (hot-reload).
    Fallback на source_emoji → 📰.
    """
    cfg = get_emoji_config()
    return cfg.detect(f"{title} {summary}", source)


def _escape_html(text: str) -> str:
    """P0-002: Экранирует спецсимволы HTML для безопасной вставки в Telegram HTML."""
    if not text:
        return ""
    return (
        text.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace('"', "&quot;")
    )


