def _classify_topic(title: str, summary: str) -> str:
    """AI-классификация темы по ключевым словам (P3-006)."""
    text = f"{title} {summary}".lower()
    scores = {}
    for topic, keywords in _TOPIC_KEYWORDS.items():
        score = sum(1 for kw in keywords if kw.lower() in text)
        if score > 0:
            scores[topic] = score
    if not scores:
        return ""
    sorted_topics = sorted(scores.items(), key=lambda x: x[1], reverse=True)
    top = [t for t, s in sorted_topics if s >= 2][:2]
    if not top and sorted_topics:
        top = [sorted_topics[0][0]]
    return " ".join(f"#{t}" for t in top)


def format_news_post(article, variant_config=None):
    """
    Форматирует пост с AI-анализом.
    P3-002: Поддержка A/B вариантов через variant_config.
    P0-002: Все динамические строки экранируются для безопасного HTML.
    """
    title = (article.get("title", "") or "").strip()
    summary = article.get("summary", "") or ""
    link = article.get("link", "")
    # UTM-метки для отслеживания трафика из Telegram в Яндекс.Метрике
    if link:
        utm = "utm_source=smartnewsai&utm_medium=telegram&utm_campaign=news_post"
        if "?" in link:
            link = link + "&" + utm
        else:
            link = link + "?" + utm
        article["link"] = link  # обновляем в article для последующего использования
    source = article.get("source", "News")
    ai_comment = (article.get("ai_comment") or "").strip()

    # P3-002: Применяем конфиг A/B варианта
    if variant_config is None:
        variant_config = {
            "has_ai_comment": True,
            "has_closer_question": True,
            "has_summary": False,
        }

    emoji = _detect_topic_emoji(title, summary, source)

    # P2-005: Graceful degradation — если AI недоступен, используем summary
    if ai_comment and "AI analysis temporarily unavailable" in ai_comment:
        ai_comment = summary[:300] if summary else ""

    # AI-комментарий — основной текст поста
    # Если AI-комментария нет — fallback на оригинальный summary
    ai_block = ""
    if variant_config.get("has_ai_comment", True) and ai_comment:
        ai_clean = ai_comment.replace("📌 ", "").replace("📚 ", "").replace("✅ ", "")
        ai_clean = ai_clean.replace("**", "").replace("— ", "• ")
        ai_block = f"📌 {_escape_html(ai_clean)}\n"
    elif summary:
        # Fallback: оригинальный summary, если AI не сработал
        summary_clean = " ".join(summary.split())
        if len(summary_clean) > 20:
            if len(summary_clean) > 500:
                summary_clean = summary_clean[:500].rstrip() + "…"
            ai_block = f"📌 {_escape_html(summary_clean)}\n"

    # Closer-вопрос
    closer = ""
    if variant_config.get("has_closer_question", True):
        closers = [
            "",
            "",
            "",
            "",
            "Что думаете?",
            "Обсуждаем?",
            "Как считаете — это серьёзно?",
            "Похоже на правду?",
        ]
        closer_raw = __import__("random").choice(closers)
        if closer_raw:
            closer = f"{_escape_html(closer_raw)}\n"

    # Detect country flag for the title
    flag = _detect_country_flag(title, summary)

    # Build quote block if article has a quote
    quote_block = ""
    article_quote = article.get("quote", "").strip()
    if article_quote and len(article_quote) > 10:
        quote_clean = article_quote.replace("**", "").replace(chr(34), "")
        if len(quote_clean) > 300:
            quote_clean = quote_clean[:300].rstrip() + "..."
        quote_block = f"\n" + chr(128172) + " <i>" + chr(171) + "" + _escape_html(quote_clean) + "" + chr(187) + "</i>\n"

    # Build body text: split into 2-3 paragraphs if long enough
    body_text = ai_block.replace(chr(128204) + " ", "") if ai_block else ""
    body_paragraphs = []
    if body_text:
        sentences = body_text.replace(chr(8226) + " ", "").split(". ")
        if len(sentences) > 3:
            mid = len(sentences) // 2
            p1 = ". ".join(sentences[:mid]) + ("." if not sentences[:mid][-1].endswith(".") else "")
            p2 = ". ".join(sentences[mid:])
            body_paragraphs = [p1.strip(), p2.strip()]
        else:
            body_paragraphs = [body_text.strip()]

    body = "\n\n".join(body_paragraphs)

    cta = chr(128073) + " <b>Smart_News_AI</b> — подписаться"
    link_text = chr(128279) + " <a href=\"" + link + "\">Читать полностью</a>"

    message = f"""{flag} <b>{_escape_html(title)}</b>{quote_block}\n\n{body}\n\n{closer}\n{cta}\n\n{link_text}"""
    return message.strip()
